# Neon PostgreSQL connection string (from Vercel Storage)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Resend API key (from resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Admin password for the admin panel
ADMIN_PASSWORD="change-me"

# Secret for iron-session cookies (min 32 characters)
SESSION_SECRET="at-least-32-characters-long-secret-here"
