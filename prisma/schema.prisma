generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  country   String
  city      String @default("")
  budget    Int    @default(0)
  createdAt DateTime @default(now())
}
